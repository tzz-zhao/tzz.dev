---
import BaseHeader from '@/components/layout/base-header.astro'
import Footer from '@/components/layout/footer.astro'
const locale = Astro.currentLocale
---
<!DOCTYPE html>
<html lang={ locale }>
<head>
    <BaseHeader />
</head>
<body class="min-h-screen flex flex-col">
    <main class="flex-grow">
        <slot />
    </main>
    <Footer />
</body>
</html>